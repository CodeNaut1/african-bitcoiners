# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (Homebrew PostgreSQL): postgresql://admin@localhost:5432/african_bitcoiners_dev
# Staging/production: use the DATABASE_URL from your Neon or Render Postgres service
DATABASE_URI=postgresql://admin@localhost:5432/african_bitcoiners_dev

# ─── Payload ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-32-character-random-secret
# Set to true after schema changes (e.g. enabling localization) to auto-sync Postgres tables in dev
PAYLOAD_PUSH=false

# ─── Next.js / Site ──────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Staging: https://staging.bitcoiners.africa
# Production: https://bitcoiners.africa
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Storage Adapter ─────────────────────────────────────────────────────────
# Use "local" for development (stores in public/media/)
# Use "r2" for staging/production (Cloudflare R2 bucket)
STORAGE_ADAPTER=local

# ─── Cloudflare R2 (required when STORAGE_ADAPTER=r2) ────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=african-bitcoiners-media
R2_PUBLIC_URL=https://media.bitcoiners.africa

# ─── Blink API (Lightning donations) ─────────────────────────────────────────
BLINK_API_KEY=your-blink-api-key
BLINK_WALLET_ID=your-blink-wallet-id
BLINK_WEBHOOK_SECRET=your-blink-webhook-secret

# ─── ActiveCampaign ──────────────────────────────────────────────────────────
# List mappings are managed via Admin → ActiveCampaign Settings (no env vars needed)
ACTIVECAMPAIGN_API_URL=https://africanbitcoiners.api-us1.com
ACTIVECAMPAIGN_API_KEY=your-activecampaign-api-key

# ─── Gmail API (domain-wide delegation) ──────────────────────────────────────
GMAIL_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GMAIL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
GMAIL_DELEGATED_USER=hello@bitcoiners.africa

# ─── Google Sheets API ────────────────────────────────────────────────────────
# Service account (can share same SA as Gmail, or separate one)
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
# Legacy per-sheet env vars (used until EM fills in the Google Sheets Settings global)
GSHEET_VOLUNTEERS=
GSHEET_FEEDBACK_BOUNTY=
GSHEET_BFB_FEEDBACK=
GSHEET_NPS=
GSHEET_MIAB=
GSHEET_GRAD=

# ─── Team Notification Emails (comma-separated) ───────────────────────────────
# community — Meetups, Map locations, Volunteers, Mining, Ecosystem
EMAIL_GROUP_COMMUNITY=community@bitcoiners.africa
# general   — Contact, Feedback Bounty, NPS, Jobs, MIAB, Partnerships
EMAIL_GROUP_GENERAL=general@bitcoiners.africa
# sensitive — Donations, Admin security alerts
EMAIL_GROUP_SENSITIVE=sensitive@bitcoiners.africa
# test      — Staging / QA notifications
EMAIL_GROUP_TEST=test@bitcoiners.africa

# ─── Analytics / GTM ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Chatbot ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
CHATBOT_MAX_MESSAGES_PER_HOUR=5
CHATBOT_MAX_MESSAGES_PER_DAY=15
CHATBOT_MAX_MESSAGES_PER_CONVERSATION=20
CHATBOT_GLOBAL_DAILY_LIMIT=200

# ─── WordPress (migration only — not needed after import is complete) ─────────
WP_API_URL=https://bitcoiners.africa/wp-json/wp/v2

# ─── QA / Launch ─────────────────────────────────────────────────────────────
# Base URL for HTTP smoke tests: QA_BASE_URL=https://staging.bitcoiners.africa pnpm qa
# Strict production env check: QA_STRICT=true pnpm qa
# Generate with: openssl rand -base64 32
PREVIEW_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-random-secret
