{
  "name": "african-bitcoiners",
  "version": "1.0.0",
  "description": "bitcoiners.africa — rebuilt on Next.js 15 + Payload CMS 3",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS='--no-deprecation --max-old-space-size=6144' next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm install",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/seed.ts",
    "seed:system-pages": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/seed-system-pages.ts",
    "seed:inflation": "cross-env NODE_OPTIONS='--no-deprecation' tsx --env-file=.env scripts/seed-inflation-data.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "export:wp": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/export-wp-content.ts",
    "import:pages": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/import-pages.ts",
    "import:newsletters": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/import-newsletters.ts",
    "import:media": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/migrate-media.ts",
    "import:legacy": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/import-legacy-data.ts",
    "redirects:generate": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/generate-redirects.ts",
    "fix:meta": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/fix-meta-titles.ts",
    "seo:bulk": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/bulk-seo-update.ts",
    "seo:default-image": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/set-default-seo-image.ts",
    "forms:task3": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/upsert-task3-forms.ts",
    "qa": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/prelaunch-check.ts",
    "launch:precheck": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/launch-precheck.ts",
    "upload:media": "cross-env NODE_OPTIONS='--no-deprecation' tsx --env-file=.env scripts/upload-media-to-r2.ts",
    "register:media": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/register-r2-media.ts",
    "rewrite:urls": "cross-env NODE_OPTIONS='--no-deprecation' tsx --env-file=.env scripts/rewrite-media-urls.ts",
    "restore:homepage-images": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/restore-homepage-images.ts",
    "fix:homepage": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/fix-homepage-content.ts",
    "strip:gforms": "cross-env NODE_OPTIONS=--no-deprecation tsx --env-file=.env scripts/strip-gforms.ts",
    "convert:quiz": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/convert-quiz.ts",
    "import:quiz-questions": "cross-env NODE_OPTIONS='--no-deprecation' tsx --env-file=.env scripts/import-quiz-questions.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@payloadcms/admin-bar": "3.85.1",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/live-preview-react": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/plugin-form-builder": "3.85.1",
    "@payloadcms/plugin-nested-docs": "3.85.1",
    "@payloadcms/plugin-redirects": "3.85.1",
    "@payloadcms/plugin-search": "3.85.1",
    "@payloadcms/plugin-seo": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-s3": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "graphql": "^16.8.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "0.563.0",
    "next": "16.2.6",
    "next-sitemap": "^4.2.3",
    "openai": "^6.45.0",
    "papaparse": "^5.5.3",
    "payload": "3.85.1",
    "pdf-lib": "^1.17.1",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.71.1",
    "react-qr-code": "^2.2.0",
    "recharts": "^3.9.2",
    "resend": "^6.14.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "22.19.9",
    "@types/papaparse": "^5.3.16",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "20.x",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
